spring:
  application:
    name: nhl-spring-app
  devtools:
    restart:
      enabled: false
  datasource:
    url: jdbc:postgresql://localhost:5432/nhldb
    driver-class-name: org.postgresql.Driver
    username: postgres
    password: SUA_SENHA_AQUI
  jpa:
    hibernate:
      ddl-auto: none
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.PostgreSQLDialect
    defer-datasource-initialization: true
  sql:
    init:
      mode: always

server:
  port: 8081
